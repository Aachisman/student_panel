<!DOCTYPE html>
<html>
<head>
<title>Login</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="h-screen flex items-center justify-center bg-gradient-to-br from-indigo-200 via-purple-200 to-pink-200">

<form action="/login" method="POST" class="bg-white/70 backdrop-blur-lg p-10 rounded-xl shadow-xl w-96">

<h1 class="text-3xl font-bold text-center mb-6 text-indigo-700">
Student Portal
</h1>
<input type="text" name="username" placeholder="Username"
class="border p-3 w-full mb-4 rounded"/>

<input type="password" name="password" placeholder="Password"
class="border p-3 w-full mb-6 rounded"/>

<button class="bg-indigo-600 text-white w-full p-3 rounded" type="submit">
Login
</button>
</form>



</body>
</html>